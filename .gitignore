# =============================================================================
# VoiceCraft — .gitignore
# Monorepo: apps/web (Next.js 16 + pnpm) · apps/agent (Python + uv)
# =============================================================================


# -----------------------------------------------------------------------------
# 1. Next.js
# -----------------------------------------------------------------------------
.next/
out/
standalone/
.vercel/


# -----------------------------------------------------------------------------
# 2. Node / pnpm
#    - node_modules is never committed
#    - pnpm-lock.yaml IS committed (do not add it here)
# -----------------------------------------------------------------------------
node_modules/
.pnp
.pnp.js


# -----------------------------------------------------------------------------
# 3. Python / uv
#    - uv.lock IS committed (do not add it here)
# -----------------------------------------------------------------------------
.venv/
__pycache__/
*.py[cod]
*.pyo
*.pyc
.python-version
dist/
build/
*.egg-info/
*.egg
site-packages/


# -----------------------------------------------------------------------------
# 4. Environment files
#    - .env.example is safe to commit and should be
#    - All other .env variants are gitignored
# -----------------------------------------------------------------------------
.env
.env.local
.env.*.local
.env.development.local
.env.test.local
.env.production.local
# Explicitly keep the example template
!.env.example


# -----------------------------------------------------------------------------
# 5. OS files
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db


# -----------------------------------------------------------------------------
# 6. Editor / IDE files
#    - Keep .vscode/extensions.json so teammates get recommended extensions
# -----------------------------------------------------------------------------
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?


# -----------------------------------------------------------------------------
# 7. TypeScript build info
# -----------------------------------------------------------------------------
*.tsbuildinfo
next-env.d.ts


# -----------------------------------------------------------------------------
# 8. Logs
# -----------------------------------------------------------------------------
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*


# -----------------------------------------------------------------------------
# 9. Data files (runtime JSON store)
# -----------------------------------------------------------------------------
data/*.json


# -----------------------------------------------------------------------------
# 10. Docker
#     .dockerignore files are fine to commit — nothing extra to ignore here
# -----------------------------------------------------------------------------


# -----------------------------------------------------------------------------
# 11. Turbo
# -----------------------------------------------------------------------------
/.turbo


# -----------------------------------------------------------------------------
# 12. Testing
# -----------------------------------------------------------------------------
.pytest_cache/
htmlcov/
.coverage
.coverage.*
coverage/
coverage.xml
*.lcov
.nyc_output/
