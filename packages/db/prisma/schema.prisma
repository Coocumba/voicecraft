generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String                @id @default(cuid())
  email         String                @unique
  name          String?
  passwordHash  String
  agents        Agent[]
  conversations BuilderConversation[]
  integrations  Integration[]
  contacts      Contact[]
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
}

model Agent {
  id                String               @id @default(cuid())
  userId            String
  user              User                 @relation(fields: [userId], references: [id])
  name              String
  businessName      String
  status            AgentStatus          @default(DRAFT)
  config            Json
  voiceSettings     Json?
  phoneNumber       String?
  phoneNumberSid    String?
  phoneNumberSource String?
  liveKitTrunkId    String?
  liveKitDispatchId String?
  conversationId    String?
  conversation      BuilderConversation? @relation(fields: [conversationId], references: [id])
  calls             Call[]
  appointments      Appointment[]
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  @@index([userId])
  @@index([conversationId])
}

model Call {
  id           String      @id @default(cuid())
  agentId      String
  agent        Agent       @relation(fields: [agentId], references: [id], onDelete: Cascade)
  callerNumber String?
  duration     Int?
  outcome      CallOutcome
  transcript   String?     @db.Text
  summary      String?
  appointments Appointment[]
  createdAt    DateTime    @default(now())

  @@index([agentId])
}

model Appointment {
  id              String            @id @default(cuid())
  agentId         String
  agent           Agent             @relation(fields: [agentId], references: [id], onDelete: Cascade)
  callId          String?
  call            Call?             @relation(fields: [callId], references: [id], onDelete: SetNull)
  patientName     String
  patientPhone    String?
  scheduledAt     DateTime
  service         String
  status          AppointmentStatus @default(BOOKED)
  calendarEventId String?
  createdAt       DateTime          @default(now())

  @@index([agentId])
  @@index([callId])
}

model BuilderConversation {
  id              String             @id @default(cuid())
  userId          String
  user            User               @relation(fields: [userId], references: [id])
  agents          Agent[]
  messages        Json
  generatedConfig Json?
  status          ConversationStatus @default(IN_PROGRESS)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([userId])
}

enum AgentStatus {
  DRAFT
  ACTIVE
  INACTIVE
}

enum CallOutcome {
  COMPLETED
  MISSED
  ESCALATED
}

enum AppointmentStatus {
  BOOKED
  CANCELLED
  COMPLETED
}

enum ConversationStatus {
  IN_PROGRESS
  COMPLETED
}

model Integration {
  id           String              @id @default(cuid())
  userId       String
  user         User                @relation(fields: [userId], references: [id])
  provider     IntegrationProvider
  accessToken  String
  refreshToken String?
  expiresAt    DateTime?
  metadata     Json?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  @@unique([userId, provider])
  @@index([userId])
}

model Contact {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id])
  phone        String
  name         String?
  email        String?
  notes        String?   @db.Text
  callCount    Int       @default(0)
  lastCalledAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([userId, phone])
  @@index([userId])
}

enum IntegrationProvider {
  GOOGLE_CALENDAR
  TWILIO
}
