NEXT_PUBLIC_APP_URL=http://localhost:3000
AUTH_SECRET=generate-a-random-secret
AUTH_URL=http://localhost:3000
AUTH_TRUST_HOST=true

# Database
DATABASE_URL=postgresql://voicecraft:voicecraft@localhost:5432/voicecraft

# Builder LLM — set LLM_PROVIDER to "anthropic" (default) or "openai"
LLM_PROVIDER=anthropic
# LLM_MODEL=claude-sonnet-4-20250514    # optional — override the default model
ANTHROPIC_API_KEY=your_anthropic_api_key
# OPENAI_API_KEY=your_openai_api_key    # required when LLM_PROVIDER=openai

# LiveKit
LIVEKIT_URL=wss://your-livekit-cloud.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret

# SIP — found in LiveKit Cloud dashboard under SIP settings
LIVEKIT_SIP_DOMAIN=your-project-id.sip.livekit.cloud

# SIP credentials — you choose these, used to authenticate Twilio→LiveKit calls
LIVEKIT_SIP_USERNAME=voicecraft
LIVEKIT_SIP_PASSWORD=generate-a-strong-password

# Shared secret for agent→web auth
VOICECRAFT_API_KEY=generate-a-shared-secret

# Google Calendar OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Microsoft Outlook Calendar Integration (optional)
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# Twilio (provisioning — SID + token enables one-click phone numbers)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token

# Twilio WhatsApp (optional — needed for appointment confirmations and reminders)
# These are Meta-approved Twilio Content Template SIDs
TWILIO_WA_CONFIRMATION_SID=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WA_REMINDER_SID=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Cron job secret — used to authenticate POST /api/cron/appointment-reminders
# Vercel: set this in project settings; Vercel cron runner sends it automatically as Bearer token
# Self-hosted: pass as Authorization: Bearer header (see `make cron-reminders`)
CRON_SECRET=generate-a-strong-secret
