# VoiceCraft Web URL (for calling Next.js API)
VOICECRAFT_WEB_URL=http://localhost:3000
VOICECRAFT_API_KEY=generate-a-shared-secret

# LiveKit
LIVEKIT_URL=wss://your-livekit-cloud.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret

# Deepgram (STT)
DEEPGRAM_API_KEY=your_deepgram_api_key

# Google Gemini (LLM)
GOOGLE_API_KEY=your_google_api_key
LLM_MODEL=gemini-2.5-flash

# TTS — provider selection (openai or elevenlabs)
TTS_PROVIDER=openai
TTS_VOICE=alloy
TTS_MODEL=gpt-4o-mini-tts
OPENAI_API_KEY=your_openai_api_key

# TTS — ElevenLabs (set TTS_PROVIDER=elevenlabs to use)
ELEVENLABS_API_KEY=your_elevenlabs_api_key
