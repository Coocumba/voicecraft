# VoiceCraft Web URL (for calling Next.js API)
VOICECRAFT_WEB_URL=http://localhost:3000
VOICECRAFT_API_KEY=generate-a-shared-secret

# LiveKit
LIVEKIT_URL=wss://your-livekit-cloud.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret

# Deepgram
DEEPGRAM_API_KEY=your_deepgram_api_key

# Google Gemini
GOOGLE_API_KEY=your_google_api_key
LLM_MODEL=gemini-2.0-flash

# TTS — Together AI (Kokoro)
TOGETHER_API_KEY=your_together_api_key

# TTS — ElevenLabs (premium)
ELEVENLABS_API_KEY=your_elevenlabs_api_key
